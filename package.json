    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@three.ez/instanced-mesh": "^0.3.15",
    "@threlte/core": "^8.4.1",
    "@threlte/extras": "^9.8.1",
    "@types/node": "^25.5.0",
    "@types/three": "^0.183.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "dayjs": "^1.11.20",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "svelte-time": "^2.1.0",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "iovalkey": "^0.3.3",
    "sqlite3": "^6.0.1",
    "zeromq": "^6.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sqlite3",
      "zeromq"
